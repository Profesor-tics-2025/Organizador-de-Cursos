rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isValidCourse(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.entity is string && data.entity.size() > 0 &&
             data.userId == request.auth.uid;
    }

    function isValidSession(data) {
      return data.courseId is string &&
             data.userId == request.auth.uid;
    }

    function isValidSettings(data) {
      return data.userId == request.auth.uid;
    }

    match /courses/{courseId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidCourse(request.resource.data);
      allow update: if isDocOwner() && isValidCourse(request.resource.data);
      allow delete: if isDocOwner();
    }
    
    match /sessions/{sessionId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidSession(request.resource.data);
      allow update: if isDocOwner() && isValidSession(request.resource.data);
      allow delete: if isDocOwner();
    }

    match /settings/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId) && isValidSettings(request.resource.data);
    }
  }
}
