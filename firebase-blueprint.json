{
  "entities": {
    "Course": {
      "title": "Course",
      "description": "A teaching course managed by the freelance teacher.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "entity": { "type": "string" },
        "modality": { "type": "string", "enum": ["presencial", "teleformación", "híbrido"] },
        "location": { "type": "string" },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" },
        "totalHours": { "type": "number" },
        "schedule": { "type": "string" },
        "pricingType": { "type": "string", "enum": ["hourly", "total"] },
        "price": { "type": "number" },
        "status": { "type": "string", "enum": ["pendiente", "confirmado", "finalizado"] },
        "color": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "entity", "startDate", "endDate", "totalHours", "price", "userId"]
    },
    "Session": {
      "title": "Session",
      "description": "A specific class session within a course.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "courseId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "startTime": { "type": "string" },
        "endTime": { "type": "string" },
        "content": { "type": "string" },
        "status": { "type": "string", "enum": ["pendiente", "impartida"] },
        "userId": { "type": "string" }
      },
      "required": ["courseId", "date", "startTime", "endTime", "userId"]
    },
    "TeacherSettings": {
      "title": "TeacherSettings",
      "description": "Configuration and preferences for the teacher.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "maxHoursPerWeek": { "type": "number" },
        "availableDays": { "type": "array", "items": { "type": "string" } },
        "minHourlyRate": { "type": "number" },
        "preferredModality": { "type": "string" }
      },
      "required": ["userId"]
    },
    "Client": {
      "title": "Client",
      "description": "A client (entity or company) for whom the teacher provides services.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "cif": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["name", "userId"]
    }
  },
  "firestore": {
    "/courses/{courseId}": {
      "schema": "Course",
      "description": "Collection of courses."
    },
    "/sessions/{sessionId}": {
      "schema": "Session",
      "description": "Collection of sessions."
    },
    "/settings/{userId}": {
      "schema": "TeacherSettings",
      "description": "Teacher specific settings."
    },
    "/clients/{clientId}": {
      "schema": "Client",
      "description": "Collection of clients."
    }
  }
}
